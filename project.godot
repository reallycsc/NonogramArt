; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="数织艺术"
config/description="数织解谜点亮画册"
run/main_scene="res://scenes/main_menu.tscn"
config/quit_on_go_back=false
config/features=PackedStringArray("4.6")
boot_splash/show_image=false
config/icon="uid://c5auiemmtqyxp"

[autoload]

NonogramManager="*uid://b2ja4cpvcqoim"
GameManager="*res://scripts/autoload/game_manager.gd"
AnimationManager="*uid://cpbtx1hbc8g2t"
AudioManager="*res://scripts/autoload/audio_manager.gd"
OrientationManager="*res://scripts/autoload/orientation_manager.gd"
ToastManager="*res://scripts/autoload/toast_manager.gd"
DLCManager="*res://scripts/autoload/dlc_manager.gd"
LoadingManager="*res://scripts/autoload/loading_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/handheld/orientation=5

[editor_plugins]

enabled=PackedStringArray()

[gui]

theme/custom="res://resources/themes/chinese_theme.tres"

[importer_defaults]

texture={
&"compress/lossy_quality": 0.8,
&"compress/mode": 1
}

[input]

ui_left={
"deadzone": 0.5,
